{
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": ["totaluptime"]
  },
  "totaluptime": {
    "color": {
      "brand": {
        "cyan":   { "value": "#01ADEF", "type": "color", "description": "Primary brand colour — Edgenexus electric cyan" },
        "cyan-2": { "value": "#0192C7", "type": "color", "description": "Cyan hover / pressed" },
        "blue":   { "value": "#144586", "type": "color", "description": "Display headings + deep accents" },
        "blue-9": { "value": "#0E2F5C", "type": "color", "description": "Darkest brand surface (modal backdrops, footer base)" },
        "mint":   { "value": "#5CC4A8", "type": "color", "description": "Supporting / success / category chip" },
        "coral":  { "value": "#ff5a6e", "type": "color", "description": "Warm accent — primary acquisition CTA" },
        "coral-2":{ "value": "#e63f55", "type": "color", "description": "Coral hover / pressed" }
      },
      "surface": {
        "white":     { "value": "#FFFFFF", "type": "color" },
        "sky":       { "value": "#DFEAF2", "type": "color", "description": "Section background tint" },
        "sky-soft":  { "value": "#F2F7FB", "type": "color", "description": "Subtle hover / utility row background" },
        "line":      { "value": "#E4ECF3", "type": "color", "description": "Hairline borders & dividers" }
      },
      "text": {
        "ink":     { "value": "#202020", "type": "color", "description": "Primary body text" },
        "ink-2":   { "value": "#4A5562", "type": "color", "description": "Secondary / muted text" },
        "on-cyan": { "value": "#FFFFFF", "type": "color" },
        "on-blue": { "value": "#FFFFFF", "type": "color" }
      },
      "category": {
