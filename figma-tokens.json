      "eyebrow": { "value": "12%",   "type": "letterSpacing" }
    },
    "typography": {
      "display-xl": {
        "value": {
          "fontFamily":   "{fontFamily.sans}",
          "fontWeight":   "{fontWeight.extra}",
          "fontSize":     "{fontSize.6xl}",
          "lineHeight":   "{lineHeights.display}",
          "letterSpacing":"{letterSpacing.display}"
        },
        "type": "typography",
        "description": "Hero H1 on desktop"
      },
      "display-lg": {
        "value": {
          "fontFamily":   "{fontFamily.sans}",
          "fontWeight":   "{fontWeight.extra}",
          "fontSize":     "{fontSize.5xl}",
          "lineHeight":   "{lineHeights.display}",
          "letterSpacing":"{letterSpacing.display}"
        },
        "type": "typography",
        "description": "Hero H1 on tablet / large section H2"
      },
      "section": {
        "value": {
          "fontFamily":   "{fontFamily.sans}",
          "fontWeight":   "{fontWeight.extra}",
          "fontSize":     "{fontSize.4xl}",
          "lineHeight":   "{lineHeights.tight}",
          "letterSpacing":"{letterSpacing.display}"
        },
        "type": "typography",
        "description": "Standard section H2"
      },
      "card-title": {
        "value": {
          "fontFamily": "{fontFamily.sans}",
          "fontWeight": "{fontWeight.bold}",
          "fontSize":   "{fontSize.lg}",
          "lineHeight": "{lineHeights.tight}"
        },
        "type": "typography",
        "description": "Card H3"
      },
      "body": {
        "value": {
          "fontFamily": "{fontFamily.sans}",
          "fontWeight": "{fontWeight.regular}",
          "fontSize":   "{fontSize.base}",
          "lineHeight": "{lineHeights.normal}"
        },
        "type": "typography"
      },
      "body-small": {
        "value": {
          "fontFamily": "{fontFamily.sans}",
          "fontWeight": "{fontWeight.regular}",
          "fontSize":   "{fontSize.sm}",
          "lineHeight": "{lineHeights.normal}"
        },
        "type": "typography"
      },
      "eyebrow": {
        "value": {
          "fontFamily":   "{fontFamily.sans}",
          "fontWeight":   "{fontWeight.bold}",
          "fontSize":     "{fontSize.xs}",
          "lineHeight":   "{lineHeights.tight}",
          "letterSpacing":"{letterSpacing.eyebrow}",
          "textCase":     "uppercase"
        },
        "type": "typography",
        "description": "All-caps eyebrow label above section headings"
      },
      "button": {
        "value": {
          "fontFamily": "{fontFamily.sans}",
          "fontWeight": "{fontWeight.bold}",
          "fontSize":   "{fontSize.base}",
          "lineHeight": "{lineHeights.tight}"
        },
        "type": "typography"
      }
    },
    "spacing": {
      "1":  { "value": "4px",  "type": "spacing" },
      "2":  { "value": "8px",  "type": "spacing" },
      "3":  { "value": "12px", "type": "spacing" },
      "4":  { "value": "16px", "type": "spacing" },
      "5":  { "value": "20px", "type": "spacing" },
      "6":  { "value": "24px", "type": "spacing" },
      "8":  { "value": "32px", "type": "spacing" },
      "10": { "value": "40px", "type": "spacing" },
      "12": { "value": "48px", "type": "spacing" },
      "16": { "value": "64px", "type": "spacing" },
      "20": { "value": "80px", "type": "spacing" }
    },
    "borderRadius": {
      "sm":   { "value": "4px",   "type": "borderRadius" },
      "md":   { "value": "8px",   "type": "borderRadius" },
      "lg":   { "value": "12px",  "type": "borderRadius", "description": "Cards, tiles" },
      "xl":   { "value": "16px",  "type": "borderRadius", "description": "Mega-menu, sheets" },
      "full": { "value": "9999px","type": "borderRadius", "description": "Pills, buttons" }
    },
    "border": {
      "hairline": {
        "value": {
          "color": "{color.surface.line}",
          "width": "1px",
          "style": "solid"
        },
        "type": "border"
      },
      "button-ghost": {
        "value": {
          "color": "{color.brand.blue}",
          "width": "1.5px",
          "style": "solid"
        },
        "type": "border"
      }
    }
  }
}
