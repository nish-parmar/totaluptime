        "dns":      { "value": "{color.brand.mint}",  "type": "color", "description": "DNS services group" },
        "security": { "value": "{color.brand.coral}", "type": "color", "description": "Network & security group" },
        "company":  { "value": "{color.brand.blue}",  "type": "color", "description": "Company / Resources groups" }
      }
    },
    "fontFamily": {
      "sans": { "value": "Montserrat", "type": "fontFamilies" }
    },
    "fontWeight": {
      "regular":  { "value": 400, "type": "fontWeights" },
      "medium":   { "value": 500, "type": "fontWeights" },
      "semibold": { "value": 600, "type": "fontWeights" },
      "bold":     { "value": 700, "type": "fontWeights" },
      "extra":    { "value": 800, "type": "fontWeights" }
    },
    "fontSize": {
      "xs":   { "value": "11px", "type": "fontSizes" },
      "sm":   { "value": "13px", "type": "fontSizes" },
      "base": { "value": "15px", "type": "fontSizes" },
      "lg":   { "value": "17px", "type": "fontSizes" },
      "xl":   { "value": "20px", "type": "fontSizes" },
      "2xl":  { "value": "24px", "type": "fontSizes" },
      "3xl":  { "value": "30px", "type": "fontSizes" },
      "4xl":  { "value": "36px", "type": "fontSizes" },
      "5xl":  { "value": "48px", "type": "fontSizes" },
      "6xl":  { "value": "60px", "type": "fontSizes" }
    },
    "lineHeights": {
      "display": { "value": "1.05", "type": "lineHeights" },
      "tight":   { "value": "1.1",  "type": "lineHeights" },
      "normal":  { "value": "1.35", "type": "lineHeights" },
      "relaxed": { "value": "1.6",  "type": "lineHeights" }
    },
    "letterSpacing": {
      "display": { "value": "-1.5%", "type": "letterSpacing" },
